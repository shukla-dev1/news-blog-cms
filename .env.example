HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified

# Remote Strapi transfer (npm run transfer:from) — create token in source admin: Settings → Transfer Tokens
STRAPI_TRANSFER_FROM_TOKEN=
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# DeepSeek (blog AI generation)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Cron jobs (set CRON_ENABLED=false locally to disable background tasks)
CRON_ENABLED=false
CRON_TZ=Asia/Kolkata
CRON_PUBLISH_RULE=*/1 * * * *

# Auto-generate blogs on a schedule (off by default)
CRON_BLOG_GENERATE_ENABLED=false
CRON_BLOG_GENERATE_RULE=0 9 * * 1
CRON_BLOG_GENERATE_TOPIC=
CRON_BLOG_GENERATE_AUTHOR_SLUG=
CRON_BLOG_GENERATE_BREADCRUMB=
CRON_BLOG_GENERATE_PUBLISH=false
CRON_BLOG_GENERATE_DELAY_HOURS=0
