{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "totalAmount": {
      "type": "integer"
    },
    "orderStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "paid",
        "shipped",
        "delivered",
        "cancelled"
      ]
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": [
        "COD",
        "Razorpay"
      ]
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "success",
        "failed"
      ]
    },
    "address": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "orderItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    }
  }
}
